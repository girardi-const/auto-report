# Server Configuration
NODE_ENV=development
PORT=3001
API_VERSION=v1

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/auto-report
MONGODB_DB_NAME=auto-report

# External APIs
PRODUCT_API_URL=https://api.supplier.com
PRODUCT_API_KEY=your_api_key_here
VIACEP_API_URL=https://viacep.com.br/ws

# JWT Configuration (for future auth)
JWT_SECRET=your_secret_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# Email Configuration (future feature)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Firebase Admin SDK (for authentication)
# Download service account JSON from Firebase Console
# Then paste the entire JSON as a single line here
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project"}

# Sentry — Error Monitoring
# Get your DSN from: https://sentry.io → Your Project → Settings → Client Keys
SENTRY_DSN=https://your-key@o0000000.ingest.sentry.io/0000000
