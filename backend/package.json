{
    "name": "auto-report-backend",
    "version": "1.0.0",
    "description": "Backend API for Girardi Auto Report System",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "vitest",
        "test:coverage": "vitest --coverage",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "db:seed": "tsx src/scripts/seedDatabase.ts"
    },
    "keywords": [
        "express",
        "mongodb",
        "api",
        "report",
        "girardi"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/mongoose": "^5.11.97",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.19.33",
        "@types/supertest": "^6.0.2",
        "eslint": "^8.57.0",
        "prettier": "^3.2.5",
        "supertest": "^6.3.4",
        "tsx": "^4.7.1",
        "typescript": "^5.4.2",
        "vitest": "^1.4.0"
    },
    "dependencies": {
        "@sentry/node": "^10.40.0",
        "@sentry/profiling-node": "^10.40.0",
        "cloudinary": "^2.9.0",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^8.2.1",
        "firebase-admin": "^13.6.1",
        "helmet": "^8.1.0",
        "mongoose": "^9.2.1",
        "multer": "^2.0.2",
        "winston": "^3.19.0",
        "xlsx": "^0.18.5",
        "zod": "^4.3.6"
    }
}
